{
    "server": {
        "host": "tu-servidor.com",
        "port": 8080,
        "frontend_path": "/var/www/planing-app/frontend/dist",
        "database_path": "/var/www/planing-app/planing.db"
    },
    "paths": {
        "api_prefix": "/api",
        "static_assets": "/assets",
        "spa_fallback": "/"
    },
    "deployment": {
        "ssh_user": "usuario",
        "ssh_port": 22,
        "service_name": "planing-app",
        "service_user": "www-data",
        "service_group": "www-data"
    },
    "notes": {
        "backend": "Sirve el frontend desde la ruta configurada en frontend_path",
        "database": "El backend busca la base de datos en database_path",
        "api_endpoints": [
            "/api/obras",
            "/api/operarios",
            "/api/planings",
            "/api/planings/date/{fecha}",
            "/api/planings/batch"
        ],
        "important": "Asegúrate de que los directorios existan y tengan los permisos correctos en el servidor"
    }
}