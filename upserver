#!/bin/bash

# Script para iniciar el servidor backend y frontend
# Guarda los PIDs en archivos para poder detenerlos después

# Directorio para archivos PID y logs
PID_DIR="./pids"
LOG_DIR="./logs"
BACKEND_PID_FILE="$PID_DIR/backend.pid"
FRONTEND_PID_FILE="$PID_DIR/frontend.pid"
BACKEND_LOG_FILE="$LOG_DIR/backend.log"
FRONTEND_LOG_FILE="$LOG_DIR/frontend.log"

# Crear directorios si no existen
mkdir -p "$PID_DIR" "$LOG_DIR"

# Función para limpiar archivos PID si el proceso ya no existe
cleanup_stale_pids() {
    if [ -f "$BACKEND_PID_FILE" ]; then
        BACKEND_PID=$(cat "$BACKEND_PID_FILE")
        if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
            echo "Eliminando PID obsoleto del backend: $BACKEND_PID"
            rm -f "$BACKEND_PID_FILE"
        fi
    fi

    if [ -f "$FRONTEND_PID_FILE" ]; then
        FRONTEND_PID=$(cat "$FRONTEND_PID_FILE")
        if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
            echo "Eliminando PID obsoleto del frontend: $FRONTEND_PID"
            rm -f "$FRONTEND_PID_FILE"
        fi
    fi
}

# Verificar si ya hay procesos en ejecución
check_running_processes() {
    if [ -f "$BACKEND_PID_FILE" ] && kill -0 $(cat "$BACKEND_PID_FILE") 2>/dev/null; then
        echo "El backend ya está en ejecución (PID: $(cat "$BACKEND_PID_FILE"))"
        return 1
    fi

    if [ -f "$FRONTEND_PID_FILE" ] && kill -0 $(cat "$FRONTEND_PID_FILE") 2>/dev/null; then
        echo "El frontend ya está en ejecución (PID: $(cat "$FRONTEND_PID_FILE"))"
        return 1
    fi

    return 0
}

# Limpiar PIDs obsoletos
cleanup_stale_pids

# Verificar si ya hay procesos en ejecución
if ! check_running_processes; then
    echo "Usa './downserver' para detener los servidores primero."
    exit 1
fi

echo "Iniciando servidores..."

# Iniciar backend
echo "Iniciando backend..."
cd backend
nohup go run main.go > "../$BACKEND_LOG_FILE" 2>&1 &
BACKEND_PID=$!
echo "$BACKEND_PID" > "../$BACKEND_PID_FILE"
echo "Backend iniciado con PID: $BACKEND_PID (logs: $BACKEND_LOG_FILE)"
cd ..

# Iniciar frontend
echo "Iniciando frontend..."
cd frontend
# npm run dev puede generar subprocesos, usamos setsid para mantenerlo en background
setsid npm run dev > "../$FRONTEND_LOG_FILE" 2>&1 &
FRONTEND_PID=$!
echo "$FRONTEND_PID" > "../$FRONTEND_PID_FILE"
echo "Frontend iniciado con PID: $FRONTEND_PID (logs: $FRONTEND_LOG_FILE)"
cd ..

# Esperar un momento para que los procesos se estabilicen
sleep 2

# Verificar que los procesos siguen ejecutándose
if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo "ERROR: El backend no se pudo iniciar correctamente."
    echo "Revisa los logs: $BACKEND_LOG_FILE"
    rm -f "$BACKEND_PID_FILE"
    exit 1
fi

if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
    echo "ERROR: El frontend no se pudo iniciar correctamente."
    echo "Revisa los logs: $FRONTEND_LOG_FILE"
    rm -f "$FRONTEND_PID_FILE"
    exit 1
fi

echo ""
echo "Servidores iniciados correctamente:"
echo "  Backend:  PID $BACKEND_PID (http://localhost:8080)"
echo "  Frontend: PID $FRONTEND_PID (http://localhost:5173)"
echo ""
echo "Logs disponibles en:"
echo "  Backend:  $BACKEND_LOG_FILE"
echo "  Frontend: $FRONTEND_LOG_FILE"
echo ""
echo "Para detener los servidores, ejecuta: ./downserver"
echo "Para ver los logs en tiempo real:"
echo "  tail -f $BACKEND_LOG_FILE"
echo "  tail -f $FRONTEND_LOG_FILE"