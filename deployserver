#!/bin/bash

# Script simplificado para desplegar la aplicación
# Uso: ./deployserver [usuario] [ip-servidor] [opción]

# Colores para salida
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuración por defecto (se puede sobrescribir con argumentos)
SERVER_USER="${1:-usuario}"
SERVER_HOST="${2:-localhost}"
SERVER_PORT="22"
SERVER_BASE_DIR="/var/www/planing-app"

# Configuración local
LOCAL_BACKEND_DIR="./backend"
LOCAL_FRONTEND_DIR="./frontend"
LOCAL_DB_FILE="./planing.db"
BUILD_DIR="./build"

# Funciones de utilidad
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

check_command() {
    if ! command -v "$1" &> /dev/null; then
        print_error "El comando '$1' no está instalado. Por favor, instálalo primero."
        exit 1
    fi
}

# Verificar comandos necesarios
check_command "ssh"
check_command "rsync"
check_command "go"
check_command "npm"

# Función para construir el proyecto
build_project() {
    print_info "Construyendo proyecto..."

    # Crear directorio de build si no existe
    mkdir -p "$BUILD_DIR"

    # Construir backend
    print_info "Construyendo backend..."
    cd "$LOCAL_BACKEND_DIR"
    if ! go build -o "../$BUILD_DIR/planing-app" main.go; then
        print_error "Error al construir el backend"
        exit 1
    fi
    cd ..

    # Construir frontend
    print_info "Construyendo frontend..."
    cd "$LOCAL_FRONTEND_DIR"
    if ! npm run build; then
        print_error "Error al construir el frontend"
        exit 1
    fi
    cd ..

    # Copiar frontend construido al directorio de build
    print_info "Copiando frontend construido..."
    rm -rf "$BUILD_DIR/dist"
    cp -r "$LOCAL_FRONTEND_DIR/dist" "$BUILD_DIR/"

    # Copiar base de datos (si existe)
    if [ -f "$LOCAL_DB_FILE" ]; then
        print_info "Copiando base de datos..."
        cp "$LOCAL_DB_FILE" "$BUILD_DIR/"
    else
        print_warning "Base de datos no encontrada: $LOCAL_DB_FILE"
        print_warning "Se usará la base de datos existente en el servidor o se creará una nueva."
    fi

    print_success "Proyecto construido en: $BUILD_DIR"
}

# Función para desplegar al servidor
deploy_to_server() {
    print_info "Desplegando a $SERVER_USER@$SERVER_HOST..."

    # Verificar conexión SSH
    print_info "Verificando conexión SSH..."
    if ! ssh -p "$SERVER_PORT" "$SERVER_USER@$SERVER_HOST" "echo '✓ Conexión SSH exitosa'" &> /dev/null; then
        print_error "No se puede conectar al servidor $SERVER_HOST"
        print_error "Verifica:"
        print_error "  1. Que el servidor esté accesible"
        print_error "  2. Que las credenciales SSH sean correctas"
        print_error "  3. Que el puerto $SERVER_PORT esté abierto"
        exit 1
    fi

    # Crear directorios en el servidor
    print_info "Creando directorios en el servidor..."
    ssh -p "$SERVER_PORT" "$SERVER_USER@$SERVER_HOST" "
        echo 'Creando estructura de directorios...'
        sudo mkdir -p $SERVER_BASE_DIR/frontend
        sudo chmod 755 $SERVER_BASE_DIR
    "

    # Subir los 3 archivos esenciales
    print_info "Subiendo backend..."
    scp -P "$SERVER_PORT" "$BUILD_DIR/planing-app" "$SERVER_USER@$SERVER_HOST:$SERVER_BASE_DIR/"

    print_info "Subiendo frontend..."
    scp -P "$SERVER_PORT" -r "$BUILD_DIR/dist" "$SERVER_USER@$SERVER_HOST:$SERVER_BASE_DIR/frontend/"

    print_info "Subiendo base de datos..."
    if [ -f "$BUILD_DIR/planing.db" ]; then
        scp -P "$SERVER_PORT" "$BUILD_DIR/planing.db" "$SERVER_USER@$SERVER_HOST:$SERVER_BASE_DIR/"
    else
        print_warning "No se encontró base de datos para subir"
    fi

    # Configurar permisos básicos
    print_info "Configurando permisos..."
    ssh -p "$SERVER_PORT" "$SERVER_USER@$SERVER_HOST" "
        echo 'Configurando permisos...'
        sudo chmod 755 $SERVER_BASE_DIR/planing-app
        if [ -f $SERVER_BASE_DIR/planing.db ]; then
            sudo chmod 644 $SERVER_BASE_DIR/planing.db
        fi
    "

    print_success "Despliegue completado"
    print_info "Para ejecutar manualmente:"
    print_info "  ssh $SERVER_USER@$SERVER_HOST"
    print_info "  cd $SERVER_BASE_DIR && ./planing-app"
    print_info ""
    print_info "La aplicación estará en: http://$SERVER_HOST:8080"
}

# Función para verificar el despliegue
verify_deployment() {
    print_info "Verificando despliegue..."

    # Verificar que los archivos existen
    print_info "Verificando archivos en servidor..."
    ssh -p "$SERVER_PORT" "$SERVER_USER@$SERVER_HOST" "
        echo 'Archivos en $SERVER_BASE_DIR:'
        ls -la $SERVER_BASE_DIR/
        echo ''
        echo 'Frontend en $SERVER_BASE_DIR/frontend/dist:'
        ls -la $SERVER_BASE_DIR/frontend/dist/ 2>/dev/null || echo 'No encontrado'
    "

    # Verificar que la aplicación se puede ejecutar
    print_info "Probando ejecución del backend..."
    if ssh -p "$SERVER_PORT" "$SERVER_USER@$SERVER_HOST" "cd $SERVER_BASE_DIR && timeout 2 ./planing-app --help 2>&1 || echo '✓ Binario ejecutable'"; then
        print_success "Backend listo para ejecutar"
    else
        print_warning "Backend podría tener problemas"
    fi

    print_info "Para probar la aplicación:"
    print_info "  1. ssh $SERVER_USER@$SERVER_HOST"
    print_info "  2. cd $SERVER_BASE_DIR"
    print_info "  3. ./planing-app"
    print_info "  4. Abrir http://$SERVER_HOST:8080 en el navegador"
}

# Función para mostrar ayuda
show_help() {
    echo "Uso: $0 [USUARIO] [IP-SERVIDOR] [OPCIÓN]"
    echo ""
    echo "Ejemplos:"
    echo "  $0 usuario 192.168.1.100           # Build + Deploy + Verify"
    echo "  $0 usuario 192.168.1.100 build     # Solo construir"
    echo "  $0 usuario 192.168.1.100 deploy    # Construir y desplegar"
    echo "  $0 usuario 192.168.1.100 verify    # Verificar despliegue"
    echo "  $0 usuario 192.168.1.100 help      # Mostrar ayuda"
    echo ""
    echo "Opciones:"
    echo "  build     Construir el proyecto localmente"
    echo "  deploy    Desplegar al servidor (incluye build)"
    echo "  verify    Verificar el despliegue actual"
    echo "  full      Build + Deploy + Verify (por defecto)"
    echo "  help      Mostrar esta ayuda"
    echo ""
    echo "Requisitos:"
    echo "  1. Acceso SSH con clave pública al servidor"
    echo "  2. Usuario con permisos sudo en el servidor"
    echo ""
    echo "Archivos que se suben:"
    echo "  1. Backend compilado (planing-app)"
    echo "  2. Frontend construido (frontend/dist/)"
    echo "  3. Base de datos (planing.db)"
    echo ""
    echo "Rutas en servidor:"
    echo "  /var/www/planing-app/planing-app      # Backend"
    echo "  /var/www/planing-app/frontend/dist/   # Frontend"
    echo "  /var/www/planing-app/planing.db       # Base de datos"
}

# Procesar argumentos
ACTION="${3:-full}"

case "$ACTION" in
    "build")
        build_project
        ;;
    "deploy")
        build_project
        deploy_to_server
        ;;
    "verify")
        verify_deployment
        ;;
    "full")
        build_project
        deploy_to_server
        verify_deployment
        ;;
    "help"|"-h"|"--help")
        show_help
        exit 0
        ;;
    *)
        print_error "Opción desconocida: $ACTION"
        echo ""
        show_help
        exit 1
        ;;
esac

print_info "Proceso completado a las $(date)"