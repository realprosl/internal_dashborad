#!/bin/bash

# Script para verificar el estado de los servidores

# Directorio para archivos PID
PID_DIR="./pids"
BACKEND_PID_FILE="$PID_DIR/backend.pid"
FRONTEND_PID_FILE="$PID_DIR/frontend.pid"

echo "Estado de los servidores:"
echo "=========================="

# Verificar backend
if [ -f "$BACKEND_PID_FILE" ]; then
    BACKEND_PID=$(cat "$BACKEND_PID_FILE")
    if kill -0 "$BACKEND_PID" 2>/dev/null; then
        echo "✓ Backend:  EN EJECUCIÓN (PID: $BACKEND_PID, Puerto: 8080)"
        echo "  URL: http://localhost:8080"
    else
        echo "✗ Backend:  DETENIDO (PID obsoleto: $BACKEND_PID)"
    fi
else
    echo "✗ Backend:  NO INICIADO"
fi

# Verificar frontend
if [ -f "$FRONTEND_PID_FILE" ]; then
    FRONTEND_PID=$(cat "$FRONTEND_PID_FILE")
    if kill -0 "$FRONTEND_PID" 2>/dev/null; then
        echo "✓ Frontend: EN EJECUCIÓN (PID: $FRONTEND_PID, Puerto: 5173)"
        echo "  URL: http://localhost:5173"
    else
        echo "✗ Frontend: DETENIDO (PID obsoleto: $FRONTEND_PID)"
    fi
else
    echo "✗ Frontend: NO INICIADO"
fi

echo ""
echo "Comandos disponibles:"
echo "  ./upserver    - Iniciar servidores"
echo "  ./downserver  - Detener servidores"
echo "  ./status      - Ver estado actual"