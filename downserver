#!/bin/bash

# Script para detener los servidores backend y frontend
# Lee los PIDs guardados por upserver

# Directorio para archivos PID
PID_DIR="./pids"
BACKEND_PID_FILE="$PID_DIR/backend.pid"
FRONTEND_PID_FILE="$PID_DIR/frontend.pid"

# Función para detener un proceso y su grupo de procesos
stop_process() {
    local process_name="$1"
    local pid_file="$2"

    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")

        if kill -0 "$pid" 2>/dev/null; then
            echo "Deteniendo $process_name (PID: $pid)..."

            # Intentar terminar el proceso y su grupo de procesos
            kill -- -"$pid" 2>/dev/null || kill "$pid" 2>/dev/null

            # Esperar a que el proceso termine (más tiempo para procesos complejos)
            local wait_count=0
            while kill -0 "$pid" 2>/dev/null && [ $wait_count -lt 15 ]; do
                sleep 0.5
                wait_count=$((wait_count + 1))
            done

            # Si aún está ejecutándose, forzar terminación
            if kill -0 "$pid" 2>/dev/null; then
                echo "Forzando terminación de $process_name (PID: $pid)..."
                kill -9 -- -"$pid" 2>/dev/null || kill -9 "$pid" 2>/dev/null
                sleep 1
            fi

            # Verificar que el proceso realmente se detuvo
            if kill -0 "$pid" 2>/dev/null; then
                echo "ADVERTENCIA: $process_name (PID: $pid) podría no haberse detenido completamente."
            else
                echo "$process_name detenido."
            fi

            rm -f "$pid_file"
        else
            echo "$process_name no está en ejecución (PID: $pid)."
            rm -f "$pid_file"
        fi
    else
        echo "Archivo PID para $process_name no encontrado: $pid_file"
    fi
}

# Función para verificar si hay procesos en ejecución
check_processes() {
    local running=0

    if [ -f "$BACKEND_PID_FILE" ]; then
        if kill -0 $(cat "$BACKEND_PID_FILE") 2>/dev/null; then
            echo "Backend en ejecución (PID: $(cat "$BACKEND_PID_FILE"))"
            running=1
        else
            echo "Backend no está en ejecución (PID obsoleto: $(cat "$BACKEND_PID_FILE"))"
            rm -f "$BACKEND_PID_FILE"
        fi
    fi

    if [ -f "$FRONTEND_PID_FILE" ]; then
        if kill -0 $(cat "$FRONTEND_PID_FILE") 2>/dev/null; then
            echo "Frontend en ejecución (PID: $(cat "$FRONTEND_PID_FILE"))"
            running=1
        else
            echo "Frontend no está en ejecución (PID obsoleto: $(cat "$FRONTEND_PID_FILE"))"
            rm -f "$FRONTEND_PID_FILE"
        fi
    fi

    return $running
}

echo "Verificando servidores en ejecución..."
echo ""

# Verificar si hay procesos en ejecución
if ! check_processes; then
    echo "No hay servidores en ejecución."

    # Limpiar directorio de PIDs si está vacío
    if [ -d "$PID_DIR" ] && [ -z "$(ls -A "$PID_DIR")" ]; then
        rmdir "$PID_DIR"
        echo "Directorio de PIDs eliminado."
    fi

    exit 0
fi

echo ""
echo "Deteniendo servidores..."
echo ""

# Detener backend
stop_process "backend" "$BACKEND_PID_FILE"

# Detener frontend
stop_process "frontend" "$FRONTEND_PID_FILE"

echo ""
echo "Servidores detenidos."

# Limpiar directorio de PIDs si está vacío
if [ -d "$PID_DIR" ] && [ -z "$(ls -A "$PID_DIR")" ]; then
    rmdir "$PID_DIR"
    echo "Directorio de PIDs eliminado."
fi

# Mostrar mensaje final
echo ""
echo "Para verificar si quedaron procesos huérfanos:"
echo "  ps aux | grep -E '(go run main|npm run dev)' | grep -v grep"